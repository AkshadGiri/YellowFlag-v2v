# ===== AUTH =====
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRE=30d

# ===== GOOGLE MAPS (Geocoding API only - no map rendering needed) =====
# Enable "Geocoding API" in Google Cloud Console for this key
GOOGLE_MAPS_API_KEY=your_google_maps_geocoding_api_key

# ===== NOTIFICATIONS - EMAIL (Nodemailer via Gmail SMTP or any SMTP) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ===== NOTIFICATIONS - SMS (Twilio) - optional, mocked if not set =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===== POLICE / EMERGENCY SERVICES (mocked for hackathon) =====
